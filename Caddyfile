# ---------------------------------------------------------------------------- #
# Caddy reverse proxy for lawbot — automatic HTTPS (Let's Encrypt).
#
# {$DOMAIN} and {$ACME_EMAIL} are injected from the environment (docker-compose).
#   - DOMAIN=localhost  -> Caddy serves HTTPS with its internal CA (dev).
#   - DOMAIN=api.example.com -> Caddy obtains+renews a real cert automatically,
#     provided ports 80/443 are reachable and DNS points at this host.
#
# Caddy terminates TLS and proxies to the api service on the internal network.
# ---------------------------------------------------------------------------- #

{
	# ACME account email is OPTIONAL. Previously this was `email {$ACME_EMAIL}`,
	# but an EMPTY ACME_EMAIL (the dev/local default) expands to a bare `email`
	# directive, which Caddy rejects at parse time ("wrong argument count after
	# 'email'") — crashing the container on startup. Caddy still obtains and
	# renews Let's Encrypt certificates without an account email; it is only used
	# for optional expiry notices. For production, set it on the site's `tls`
	# directive (e.g. `tls you@domain`) where an empty value is not a parse error.
	# Send Caddy's own logs to stdout for the platform to collect.
	admin :2019
}

{$DOMAIN} {
	encode zstd gzip

	# Security headers (sane defaults for a JSON API).
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
		# This is an API, not a site; don't advertise the server.
		-Server
	}

	# Health checks bypass auth at the app layer; proxy straight through.
	handle /healthz {
		reverse_proxy api:8000
	}

	# Everything else (the /v1/* API + /docs) -> FastAPI.
	handle {
		reverse_proxy api:8000 {
			# Preserve client info for the app's IP-based rate limiting.
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	# Structured access logs to stdout.
	log {
		output stdout
		format json
	}
}
