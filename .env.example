# ---------------------------------------------------------------------------- #
# lawbot environment template. Copy to `.env` and fill in real values.
#   cp .env.example .env
# `.env` is git-ignored — NEVER commit real keys. Only OPENAI_API_KEY is
# strictly required; the rest have sensible defaults in config.py.
# ---------------------------------------------------------------------------- #

# --- REQUIRED -------------------------------------------------------------- #
# OpenAI key — embeddings (text-embedding-3-small @ 512d) + chat (gpt-5-mini)
# for /v1/ask, /v1/ad-review, and the colloquial->legal query rewrite.
# Set a monthly usage hard-limit in the OpenAI dashboard before going live.
OPENAI_API_KEY=sk-...

# --- Serving mode (FULL Korean-law index + hybrid + rewrite) --------------- #
# These match the prebuilt artifacts mounted at /app/artifacts (see DEPLOY).
LAWBOT_INDEX=full          # full corpus (artifacts/full_index). "medical" = old subset
LAWBOT_HYBRID=1            # BM25 + dense fusion for citation/law-name queries
LAWBOT_REWRITE=1           # LLM colloquial->legal query rewrite (per-query LLM cost)
# No-login public demo (per-IP rate-limited). 1 = open demo; 0 = key-only prod.
LAWBOT_DEMO=1

# --- Models ---------------------------------------------------------------- #
# EMBED_DIM is NOT set here: it is a code-pinned 512 invariant (config.py); a
# stale env value is ignored + warned. The embed model must match the index.
EMBED_MODEL=text-embedding-3-small
GEN_MODEL=gpt-5-mini
COLLECTION=lawbot

# --- Citation Firewall (optional) ------------------------------------------ #
# law.go.kr OpenAPI OC: enables the live 현행 조문 check in /v1/verify. Empty ->
# firewall falls back to DB-existence (parents.jsonl) only.
LAW_OC=

# --- Key store ------------------------------------------------------------- #
# SQLite key DB on the persisted /app/data volume (compose sets this). Honored
# by config.py via os.getenv. Leave as-is for the container.
API_KEYS_DB=/app/data/lawbot_keys.db

# --- TLS / domain (Caddy) -------------------------------------------------- #
# With a domain: set DOMAIN=api.yourdomain.com (+ ACME_EMAIL) -> auto HTTPS.
# Without a domain: set DOMAIN=:80 to serve plain HTTP on port 80 (no certs).
DOMAIN=localhost
ACME_EMAIL=

# --- Rate limiting (optional) ---------------------------------------------- #
# Single instance uses in-memory limiting by default. For multiple replicas,
# point at a shared backend: RATE_LIMIT_STORAGE_URI=redis://host:6379/0
# RATE_LIMIT_STORAGE_URI=memory://

# --- Upload guard (optional) ----------------------------------------------- #
# Max /v1/ad-review upload size in bytes (default 10MB).
# LAWBOT_MAX_UPLOAD_BYTES=10485760
