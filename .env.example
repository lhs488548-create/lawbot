# ---------------------------------------------------------------------------- #
# lawbot environment template. Copy to `.env` and fill in real values.
#   cp .env.example .env
# `.env` is git-ignored — NEVER commit real keys. Only OPENAI_API_KEY is
# strictly required; the rest have sensible defaults in config.py.
# ---------------------------------------------------------------------------- #

# --- REQUIRED -------------------------------------------------------------- #
# OpenAI key used for embeddings (text-embedding-3-*) and chat (gpt-4o-*).
# Set a monthly usage hard-limit in the OpenAI dashboard before going live.
OPENAI_API_KEY=sk-...

# --- Vector store ---------------------------------------------------------- #
# Local Docker Qdrant (default). For Qdrant Cloud, set the cluster URL + key:
#   QDRANT_URL=https://xxxx-xxxx.aws.cloud.qdrant.io:6333
#   QDRANT_API_KEY=<qdrant-cloud-api-key>
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
COLLECTION=lawbot

# --- Models (one knob each; must match the embedded collection's dim) ------ #
EMBED_MODEL=text-embedding-3-small
EMBED_DIM=1536
GEN_MODEL=gpt-4o-mini

# --- Rate limiting --------------------------------------------------------- #
# Shared backend so per-key limits hold across multiple api replicas.
# In-memory ("memory://") is fine for a single instance.
RATE_LIMIT_STORAGE_URI=redis://redis:6379/0

# --- TLS / domain (Caddy) -------------------------------------------------- #
# Use a real FQDN for public Let's Encrypt certs; `localhost` for dev.
DOMAIN=localhost
ACME_EMAIL=

# --- Optional -------------------------------------------------------------- #
# law.go.kr OpenAPI OC, only for the freshness/refresh tooling.
LAW_OC=
